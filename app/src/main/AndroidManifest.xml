<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <queries>
        <package android:name="com.mservice.momotransfer" />

        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="mbmobile" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="vietcombankmobile" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="tcb" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="bidvsmartbanking" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="vietinbankmobile" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="agribankmobile" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="acbapp" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="tpbankmobile" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="vpbankneo" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="vibmobile" /></intent>
        <intent><action android:name="android.intent.action.VIEW" /><data android:scheme="sacombankpay" /></intent>
    </queries>

    <application
        android:name=".TelemedicineApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TelemedicineApp">

        <activity
            android:name="com.example.telemedicineapp.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.TelemedicineApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        // Nhắc hẹn
        <service
            android:name=".core.MyFirebaseMessagingService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>